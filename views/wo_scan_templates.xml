<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- Formulario simple de cierre de OT -->
  <template id="wo_finish_form">
    <t t-call="web.layout">
      <!-- Agregamos un bloque de estilos táctiles al inicio -->
      <t t-set="head">
        <style>
          .touch-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background-color: #f8f9fa;
          }
          .custom-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 8px 16px rgba(0,0,0,0.1);
            padding: 30px;
            margin-bottom: 20px;
          }
          .touch-title {
            font-size: 2rem;
            font-weight: 700;
            color: #2b2b2b;
            margin-bottom: 10px;
            text-align: center;
          }
          .touch-subtitle {
            font-size: 1.5rem;
            color: #6c757d;
            text-align: center;
            margin-bottom: 30px;
          }
          .touch-label {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 10px;
            display: block;
          }
          .touch-input {
            width: 100%;
            height: 80px;
            font-size: 2.5rem;
            font-weight: bold;
            text-align: center;
            border: 2px solid #ced4da;
            border-radius: 12px;
            background-color: #fff;
            color: #495057;
            transition: border-color 0.15s ease-in-out;
            cursor: pointer;
            box-sizing: border-box;
          }
          .touch-input:focus, .touch-input.active {
            border-color: #86b7fe;
            outline: 0;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
            background-color: #f1f7ff;
          }
          .touch-input.input-ok.active {
            border-color: #198754;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
            background-color: #e8f5e9;
          }
          .touch-input.input-rej.active {
            border-color: #dc3545;
            box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
            background-color: #ffebee;
          }
          .touch-btn-submit {
            width: 100%;
            height: 100px;
            font-size: 2.2rem;
            font-weight: bold;
            border-radius: 12px;
            background-color: #0d6efd;
            color: white;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(13,110,253,0.3);
            transition: background-color 0.2s, transform 0.1s;
          }
          .touch-btn-submit:active {
            background-color: #0b5ed7;
            transform: translateY(2px);
          }
          
          /* Numpad Styles */
          .numpad {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 30px;
          }
          .numpad-btn {
             height: 90px;
             font-size: 3rem;
             font-weight: bold;
             background-color: #e9ecef;
             border: 2px solid #dee2e6;
             border-radius: 12px;
             color: #212529;
             cursor: pointer;
             transition: all 0.1s;
             display: flex;
             align-items: center;
             justify-content: center;
             user-select: none;
          }
          .numpad-btn:active {
             background-color: #ced4da;
             transform: scale(0.95);
          }
          .numpad-btn.btn-del {
            background-color: #ffc107;
            border-color: #ffc107;
            color: #000;
          }
          .numpad-btn.btn-clear {
            background-color: #dc3545;
            border-color: #dc3545;
            color: #fff;
          }
          
          /* Utility Classes */
          .input-row {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
          }
          .input-col {
            flex: 1;
          }
          .text-success { color: #198754; }
          .text-danger { color: #dc3545; }
        </style>
        <script>
          document.addEventListener('DOMContentLoaded', function() {
              let activeInput = document.getElementById('ok_qty_input');
              if(activeInput) activeInput.classList.add('active');

              const inputs = document.querySelectorAll('.touch-input');
              inputs.forEach(input => {
                  input.addEventListener('click', function() {
                      inputs.forEach(i => i.classList.remove('active'));
                      this.classList.add('active');
                      activeInput = this;
                  });
                  input.addEventListener('focus', function(e) {
                      e.preventDefault();
                      this.blur();
                  });
              });

              document.querySelectorAll('.numpad-btn').forEach(btn => {
                  btn.addEventListener('click', function(e) {
                      e.preventDefault();
                      if(!activeInput) return;
                      
                      const val = this.getAttribute('data-val');
                      const action = this.getAttribute('data-action');
                      let currentVal = activeInput.value.toString();
                      
                      if(action === 'del') {
                          activeInput.value = currentVal.slice(0, -1);
                      } else if(action === 'clear') {
                          activeInput.value = '';
                      } else if(val !== null) {
                          if (val === '.' && currentVal.includes('.')) return;
                          
                          if ((currentVal === '0' || currentVal === '') && val !== '.') {
                              activeInput.value = val;
                          } else {
                              activeInput.value = currentVal + val;
                          }
                      }
                      
                      let cleanVal = activeInput.value || '0';
                      document.getElementById(activeInput.id.replace('_input', '')).value = cleanVal;
                  });
              });
          });
        </script>
      </t>
      
      <div class="touch-container">
        <div class="custom-card">
          <h1 class="touch-title"><t t-esc="title"/></h1>
          <h2 class="touch-subtitle"><t t-esc="product.display_name"/></h2>

          <t t-if="already_done">
            <div class="alert alert-info p-4" style="font-size: 1.5rem; border-radius: 12px; background:#e0f2fe; color:#0369a1; border:none;">
              <p><b>Estado:</b> Terminada</p>
              <p><b>MO:</b> <t t-esc="mo_name"/></p>
              <p><b>Responsable:</b> <t t-esc="responsable_name"/></p>
              <p><b>Producido:</b> <t t-esc="produced_total"/></p>
              <p><b>Scrap:</b> <t t-esc="scrap_total"/></p>
              <p><b>Fecha/hora:</b> <t t-esc="close_dt"/></p>
            </div>
            <p style="font-size:1.5rem; text-align:center; color:#64748b; margin-top:20px;">Esta orden ya fue finalizada.</p>
          </t>

          <t t-if="not already_done">
            <form t-att-action="'/wo/%s/finish' % wo.id" method="post" id="wo_finish_form_element">
                <!-- Variables ocultas para Odoo (post form) -->
                <input type="hidden" name="ok_qty" id="ok_qty" t-att-value="ok_default or '0'"/>
                <input type="hidden" name="rej_qty" id="rej_qty" t-att-value="rej_default or '0'"/>
                
                <div class="input-row">
                    <div class="input-col">
                        <label class="touch-label text-success">Piezas OK</label>
                        <input type="text" id="ok_qty_input" class="touch-input input-ok active" readonly="1" t-att-value="ok_default or '0'"/>
                    </div>
                    <div class="input-col">
                        <label class="touch-label text-danger">Rechazo</label>
                        <input type="text" id="rej_qty_input" class="touch-input input-rej" readonly="1" t-att-value="rej_default or '0'"/>
                    </div>
                </div>

                <!-- Teclado Numérico Visual HTML -->
                <div class="numpad">
                    <div class="numpad-btn" data-val="7">7</div>
                    <div class="numpad-btn" data-val="8">8</div>
                    <div class="numpad-btn" data-val="9">9</div>
                    <div class="numpad-btn" data-val="4">4</div>
                    <div class="numpad-btn" data-val="5">5</div>
                    <div class="numpad-btn" data-val="6">6</div>
                    <div class="numpad-btn" data-val="1">1</div>
                    <div class="numpad-btn" data-val="2">2</div>
                    <div class="numpad-btn" data-val="3">3</div>
                    <div class="numpad-btn btn-clear" data-action="clear">C</div>
                    <div class="numpad-btn" data-val="0">0</div>
                    <div class="numpad-btn btn-del" data-action="del">⌫</div>
                </div>

                <button type="submit" class="touch-btn-submit">CONFIRMAR Y SIGUIENTE</button>
            </form>
          </t>
        </div>
      </div>
    </t>
  </template>

  <!-- Pantalla de confirmación y descarga automática (mejorada visualmente) -->
  <template id="wo_finish_download">
    <t t-call="web.layout">
      <!-- Añadir tipografía legible por defecto al renderizar -->
      <t t-set="head">
        <style>
          body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; background-color: #f8f9fa;}
        </style>
      </t>
      <div class="container" style="max-width:800px; padding:40px; text-align:center; margin-top:50px; background:#fff; border-radius:16px; box-shadow:0 8px 16px rgba(0,0,0,0.1);">
          <h1 style="color:#198754; font-size:5rem; font-weight:800; margin-bottom: 20px;">✓ GUARDADO</h1>
          <p style="font-size: 2rem; color: #495057;"><t t-esc="message"/></p>
          
          <div style="margin-top: 50px; border-top: 2px dashed #eee; padding-top: 40px;">
            <p style="font-size: 1.5rem; color:#6c757d;">Preparando e imprimiendo orden siguiente...</p>
          </div>

          <form id="pdf_form" action="/report/download" method="post" style="display:none;">
            <input type="hidden" name="data" t-att-value="data_payload"/>
            <input type="hidden" name="token" value="terminal_token"/>
            <input type="hidden" name="csrf_token" t-att-value="csrf_token"/>
          </form>

          <script>
              setTimeout(function(){
                  document.getElementById("pdf_form").submit();
              }, 600);
          </script>
      </div>
    </t>
  </template>
</odoo>
