<odoo>
  <!-- ======================== -->
  <!-- ACCIONES                 -->
  <!-- ======================== -->

  <!-- Acción Planificador Original -->
  <record id="action_work_queue_plan_by_wc" model="ir.actions.act_window">
    <field name="name">Planificación general</field>
    <field name="res_model">work.queue.plan</field>
    <field name="view_mode">list,form</field>
    <field name="view_id" ref="view_work_queue_plan_tree"/>
    <field name="search_view_id" ref="view_work_queue_plan_search"/>
    <field name="target">current</field>
    <field name="help" type="html">
      <p>Seleccioná una cola para editarla o pulsá <b>Nuevo</b> para organizar el trabajo en un centro y asignarlo a un empleado.</p>
    </field>
  </record>

  <!-- Acción Por Empleado -->
  <record id="action_work_queue_item_by_employee" model="ir.actions.act_window">
    <field name="name">Carga por empleado</field>
    <field name="res_model">work.queue.item</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_work_queue_item_tree"/>
    <field name="search_view_id" ref="view_work_queue_item_search"/>
    <field name="context">{'search_default_group_by_employee': 1}</field>
    <field name="domain">[('employee_id', '!=', False), ('state', 'not in', ['done', 'cancel'])]</field>
    <field name="help" type="html">
      <p>Vista estructurada por empleado para seguir su carga.</p>
    </field>
  </record>

  <!-- Acción Por Centro -->
  <record id="action_work_queue_item_by_wc" model="ir.actions.act_window">
    <field name="name">Carga por Centro y Empleado</field>
    <field name="res_model">work.queue.item</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_work_queue_item_tree"/>
    <field name="search_view_id" ref="view_work_queue_item_search"/>
    <field name="context">{'search_default_group_by_workcenter': 1, 'search_default_group_by_employee': 1}</field>
    <field name="domain">[('employee_id', '!=', False), ('state', 'not in', ['done', 'cancel'])]</field>
    <field name="help" type="html">
      <p>Vista del trabajo activo agrupada por Centro y luego por operario asignado.</p>
    </field>
  </record>

  <!-- ======================== -->
  <!-- MENÚS                    -->
  <!-- ======================== -->

  <menuitem id="menu_work_queue_root"
            name="Cola de trabajo"
            parent="mrp.menu_mrp_root"
            sequence="80"/>

  <menuitem id="menu_work_queue_planning"
            name="Planificación"
            parent="menu_work_queue_root"
            action="action_work_queue_plan_by_wc"
            sequence="10"
            groups="mrp_work_queue.group_mrp_queue_admin,mrp_work_queue.group_mrp_queue_operator"/>

  <menuitem id="menu_work_queue_employee"
            name="Por empleado"
            parent="menu_work_queue_root"
            action="action_work_queue_item_by_employee"
            sequence="20"
            groups="mrp_work_queue.group_mrp_queue_admin,mrp_work_queue.group_mrp_queue_operator"/>

  <menuitem id="menu_work_queue_wc"
            name="Por centro de trabajo"
            parent="menu_work_queue_root"
            action="action_work_queue_item_by_wc"
            sequence="30"
            groups="mrp_work_queue.group_mrp_queue_admin,mrp_work_queue.group_mrp_queue_operator"/>
</odoo>
